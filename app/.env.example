# ─────────────────────────────────────────────────────────────
# PaperTrader frontend — environment variables (EXAMPLE)
#
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# `.env*` files are gitignored — never commit real secrets.
#
# RULES (see CLAUDE.md / ARCHITECTURE.md at the repo root):
#   • Anything prefixed VITE_ is PUBLIC — it ships to the browser.
#     Only put non-secret, publishable values here (public URLs,
#     publishable/anon keys, analytics IDs).
#   • NEVER put the market-data API key (Finnhub / Twelve Data) or any
#     server secret in a VITE_ var. Those live ONLY in Supabase secrets
#     and are used from Edge Functions — never the frontend.
#   • Server-only values (no VITE_ prefix) are read in *.server.ts files
#     or createServerFn handlers and are not bundled to the client.
# ─────────────────────────────────────────────────────────────

# ── Supabase (Phase 3+) ───────────────────────────────────────
# Both values are PUBLIC and safe for the browser. Find them in the
# Supabase dashboard → Project Settings → API.

# Supabase project URL.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable / anon key (browser-safe public key).
# New projects show a key prefixed `sb_publishable_...`; older ones an
# `anon` JWT. Either works here — both are public, never a secret.
VITE_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key

# ── Market data — HYBRID providers (Phase 5+) ─────────────────
# Both are SERVER-ONLY secrets. NO VITE_ prefix → never exposed to the browser.
# Read only inside lib/marketData (server functions), never client code.
#
# Finnhub (finnhub.io) → live quotes, symbol search, company profile
# (market cap / logo / sector). Free tier = 60 req/min but NO historical
# stock candles (premium-only).
FINNHUB_API_KEY=your_finnhub_api_key
#
# Twelve Data (twelvedata.com) → historical candles & series (charts +
# What-If Simulator). Free tier ~8 credits/min.
TWELVEDATA_API_KEY=your_twelvedata_api_key

# ── Supabase service_role key (Phase 6+) ──────────────────────
# SERVER-ONLY secret (NO VITE_ prefix). Bypasses Row-Level Security, so it must
# never reach the browser. Used only by server functions (e.g. executeTradeFn)
# to call the execute_trade() DB function. Find it in the Supabase dashboard →
# Project Settings → API → service_role / secret key.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret

# ── Snapshot writer trigger (Phase 8+) ────────────────────────
# SERVER-ONLY secret (NO VITE_). The /api/cron/snapshot endpoint requires this
# token (Authorization: Bearer <CRON_SECRET>, or ?secret=). Vercel Cron sends
# it in Phase 9. Generate one with: openssl rand -hex 24
CRON_SECRET=your_random_cron_secret

# ── AI Agent (Phase 10+) ──────────────────────────────────────
# Anthropic API key — SERVER-ONLY (NO VITE_). Powers the agent's decision
# engine (used only from server functions). Get one at console.anthropic.com.
ANTHROPIC_API_KEY=your_anthropic_api_key
# Which Claude model the agent's "thinker" uses — SERVER-ONLY (NO VITE_).
# Optional; defaults to claude-sonnet-4-6. Swap without code edits (e.g.
# claude-opus-4-8 for max reasoning, claude-haiku-4-5 for lowest cost).
AGENT_MODEL=claude-sonnet-4-6
